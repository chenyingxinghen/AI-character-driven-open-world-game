# ---------------------------
# DATABASE CONFIGURATION
# ---------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ai_narrative_game
DATABASE_USER=postgres
DATABASE_PASSWORD=zxcasdqwe123@4
DATABASE_POOL_MAX=100
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=5000

# ---------------------------
# REDIS CONFIGURATION (Optional)
# ---------------------------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ---------------------------
# LLM SERVICE CONFIGURATION
# ---------------------------
# Default LLM Provider (OPENAI | ANTHROPIC | GEMINI | OPENROUTER)
DEFAULT_LLM_PROVIDER=OpenRouter

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_DEFAULT_MODEL=gpt-3.5-turbo
OPENAI_RATE_LIMIT_RPM=60
OPENAI_RATE_LIMIT_TPM=150000
OPENAI_PRICING_INPUT=0.0015
OPENAI_PRICING_OUTPUT=0.002

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307
ANTHROPIC_RATE_LIMIT_RPM=60
ANTHROPIC_RATE_LIMIT_TPM=150000
ANTHROPIC_PRICING_INPUT=0.008
ANTHROPIC_PRICING_OUTPUT=0.024

# Google Gemini Configuration
GEMINI_API_KEY=AIzaSyBpHXAhjvgQZuOAP6psETygLoRRyHARfqI
GEMINI_DEFAULT_MODEL=gemini-2.5-flash-lite
GEMINI_RATE_LIMIT_RPM=60
GEMINI_RATE_LIMIT_TPM=150000
GEMINI_PRICING_INPUT=0
GEMINI_PRICING_OUTPUT=0

# OpenRouter Configuration
OPENROUTER_API_KEY=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
OPENROUTER_DEFAULT_MODEL=cognitivecomputations/dolphin-mistral-24b-venice-edition:free
OPENROUTER_RATE_LIMIT_RPM=60
OPENROUTER_RATE_LIMIT_TPM=150000
OPENROUTER_PRICING_INPUT=0
OPENROUTER_PRICING_OUTPUT=0

# ---------------------------
# LLM SERVICE SETTINGS
# ---------------------------
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_BACKOFF_MULTIPLIER=2
LLM_RETRY_MAX_BACKOFF_MS=10000
LLM_TIMEOUT_MS=30000

# ---------------------------
# GAME SERVER CONFIGURATION
# ---------------------------
GAME_SERVER_PORT=8080
GAME_SERVER_HOST=localhost
WEBSOCKET_URL=ws://localhost:8080

# ---------------------------
# LOGGING CONFIGURATION
# ---------------------------
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/game.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# ---------------------------
# GAME SETTINGS
# ---------------------------
GAME_SESSION_TIMEOUT_MINUTES=60
GAME_MAX_CONCURRENT_SESSIONS=100
GAME_AUTO_SAVE_INTERVAL_MINUTES=5

# ---------------------------
# DEVELOPMENT SETTINGS
# ---------------------------
NODE_ENV=development
DEBUG_MODE=true